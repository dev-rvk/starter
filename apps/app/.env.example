# ─────────────────────────────────────────────────────────────────────────────
# Starterpack App (dashboard) — environment
# Copy to .env.local. Only VITE_CLERK_PUBLISHABLE_KEY is needed for auth.
# Every VITE_* integration is a feature toggle: leave it blank to keep the
# feature disabled. Vite only exposes variables prefixed with VITE_.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL.
VITE_API_URL=http://localhost:3002

# ── Auth: Clerk (required for sign-in) ───────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=

# ── Web analytics: Google Analytics (free tier; off until set) ───────────────
VITE_GA_MEASUREMENT_ID=

# ── Product analytics: PostHog self-hosted (off until set) ───────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com

# ── Error tracking: Sentry (off until set) ───────────────────────────────────
VITE_SENTRY_DSN=
