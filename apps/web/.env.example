# ─────────────────────────────────────────────────────────────────────────────
# Starterpack Web (marketing) — environment
# Copy to .env.local. Every VITE_* integration is a feature toggle: leave it
# blank to keep that feature disabled. Vite only exposes VITE_-prefixed vars.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the dashboard app (used by call-to-action links).
VITE_APP_URL=http://localhost:3000

# ── Web analytics: Google Analytics (free tier; off until set) ───────────────
VITE_GA_MEASUREMENT_ID=

# ── Product analytics: PostHog self-hosted (off until set) ───────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com
