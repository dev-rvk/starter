# ─────────────────────────────────────────────────────────────────────────────
# Starterpack API — environment
# Copy to .env.local for local development. Every integration is a feature
# toggle: leave a key blank to keep that feature disabled (the server still
# boots). Only DATABASE_URL + Clerk are needed for the full experience.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development
PORT=3002
LOG_LEVEL=info

# CORS: comma-separated origins allowed to call the API (the Vite apps).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database (PostgreSQL). When unset, the API falls back to an in-memory store.
# dbmate also reads this variable for migrations.
DATABASE_URL=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Two modes:
# 1. Clerk (set CLERK_SECRET_KEY): full-featured auth with OAuth, MFA, etc.
# 2. Local (default when Clerk is unset): username/password auth against the DB.
#    Uses JWT tokens signed with JWT_SECRET.
CLERK_SECRET_KEY=

# HMAC secret for signing local auth JWTs. Change this in production!
# When unset in dev, falls back to a built-in dev secret.
JWT_SECRET=

# ── Payments: Stripe (off until set) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Error tracking: Sentry (off until set) ───────────────────────────────────
SENTRY_DSN=

# ── Transactional email: Resend (off until set) ──────────────────────────────
RESEND_TOKEN=
RESEND_FROM=
