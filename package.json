{
  "name": "starterpack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "bump-deps": "bunx npm-check-updates --deep -u && bun install",
    "bump-ui": "bunx shadcn@latest add --all --overwrite -c packages/design-system",
    "clean": "git clean -xdf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.8.14",
    "@types/node": "^25.3.5",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "ultracite": "7.8.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
