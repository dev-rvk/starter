{
  "name": "@repo/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.d.ts"
  },
  "scripts": {
    "generate": "swagger2openapi ../../apps/api/docs/swagger.json --outfile ./openapi.json --patch && openapi-typescript ./openapi.json -o ./src/schema.d.ts",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "openapi-typescript": "^7.6.1",
    "swagger2openapi": "^7.0.8",
    "typescript": "^5.9.3"
  }
}
