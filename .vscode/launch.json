{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: Debug Go Backend",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/apps/api/cmd/api/main.go",
      "cwd": "${workspaceFolder}/apps/api",
      "envFile": "${workspaceFolder}/apps/api/.env.local"
    },
    {
      "name": "App: Debug client-side (app)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/app"
    },
    {
      "name": "Web: Debug client-side (web)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3001",
      "webRoot": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Email: Debug client-side (email)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3003",
      "webRoot": "${workspaceFolder}/apps/email"
    }
  ]
}
